# Deny-all by default
*
.*

# Allowlist: repository metadata
!.gitignore
!VERSION
!LICENSE
!README.md
!AGENTS.md
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md

# Images (README hero, etc.)
!assets/
!assets/**

# GitHub Actions and Dependabot
!.github/
!.github/dependabot.yml
!.github/workflows/
!.github/workflows/**

# Deployment tree
!run/
!run/**
# Operator-local Ansible (copy from *.example)
run/vps-recommended/ansible/inventory.yml
run/vps-recommended/ansible/group_vars/all.yml

# SQLite placeholder at repo root (DB files stay ignored below)
!data/
!data/.keep

# Generated noise
.DS_Store
*.db
data/*.db
*.db-shm
*.db-wal
