# Copy to ${GGHSTATS_HOST_DATA}/.env.observability (outside the git clone). Pass that path to docker compose --env-file (see README.md).
# Do not commit real passwords.

# Grafana reads these only on FIRST startup with an empty Grafana data volume.
# If you change them later in this file, login credentials do NOT update — they stay in the persisted DB.
# To rotate: Grafana UI (user profile), or `grafana-cli admin reset-admin-password`, or remove the grafana_data volume (destructive).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-before-first-up

# Host port for Grafana UI (avoid clashes with other services on the host)
GRAFANA_PORT=3000

# Must match how you open Grafana in the browser (Grafana redirects / cookies).
# Local only:
GRAFANA_ROOT_URL=http://localhost:3000
#
# HTTPS via Traefik (use with docker-compose.observability.traefik.yml): set FQDN + https URL.
# DNS: A/AAAA to this host’s IP, or CNAME to a name that already points here — both are valid.
# GRAFANA_HOSTNAME=gghstats-obs.my-domain.com
# GRAFANA_ROOT_URL=https://gghstats-obs.my-domain.com

# Host port for Prometheus UI
PROMETHEUS_PORT=9090

# Node Exporter (host metrics; Grafana dashboard 1860). Default 9100.
NODE_EXPORTER_PORT=9100
