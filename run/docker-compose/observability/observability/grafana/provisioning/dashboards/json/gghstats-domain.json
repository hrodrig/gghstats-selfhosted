{
  "annotations": {
    "list": []
  },
  "description": "gghstats application metrics (sync, GitHub API, SQLite). Requires gghstats >= 0.4.0. Per-repo panels need GGHSTATS_METRICS_PER_REPO=true.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Sync & store",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Unix time of the last successful full sync. Zero means no successful sync yet on this instance.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 24 },
              { "color": "red", "value": 48 }
            ]
          },
          "unit": "h"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "((time() - gghstats_last_sync_timestamp_seconds) / 3600) and (gghstats_last_sync_timestamp_seconds > 0)",
          "refId": "A"
        }
      ],
      "title": "Hours since last successful sync",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 0,
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gghstats_repos_total",
          "legendFormat": "{{filter}}",
          "refId": "A"
        }
      ],
      "title": "Repositories in database",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 2,
          "unit": "decbytes"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gghstats_db_size_bytes",
          "refId": "A"
        }
      ],
      "title": "SQLite database size",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "green", "value": 2000 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gghstats_github_rate_limit_remaining{resource=\"core\"}",
          "refId": "A"
        }
      ],
      "title": "GitHub API rate limit (core remaining)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Mean duration of successful full syncs in the last 6 hours (histogram observed once per sync, not a continuous rate).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "decimals": 0,
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(gghstats_sync_duration_seconds_sum{status=\"success\"}[6h])) / clamp_min(sum(increase(gghstats_sync_duration_seconds_count{status=\"success\"}[6h])), 1)",
          "refId": "A"
        }
      ],
      "title": "Last successful sync duration (6h avg)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "h"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "((time() - gghstats_last_sync_timestamp_seconds) / 3600) and (gghstats_last_sync_timestamp_seconds > 0)",
          "legendFormat": "hours",
          "refId": "A"
        }
      ],
      "title": "Hours since last successful sync (trend)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "panels": [],
      "title": "GitHub API",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * sum(increase(gghstats_github_api_requests_total{status!=\"success\"}[1h])) / clamp_min(sum(increase(gghstats_github_api_requests_total[1h])), 1)",
          "refId": "A"
        }
      ],
      "title": "GitHub API non-success (1h %)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 14 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gghstats_github_api_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "GitHub API request rate by status",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gghstats_github_api_requests_total[5m])) by (endpoint, status)",
          "legendFormat": "{{endpoint}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "GitHub API request rate by endpoint",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "panels": [],
      "title": "HTTP (gghstats app)",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(gghstats_http_requests_total{route!=\"metrics\"}[5m])) by (route, status)",
          "legendFormat": "{{route}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "HTTP request rate (excluding /metrics scrape)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "panels": [],
      "title": "Per-repository (optional)",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 40 },
      "id": 11,
      "options": {
        "code": { "language": "plaintext", "showLineNumbers": false },
        "content": "Panels below need **gghstats >= 0.4.0** with **`GGHSTATS_METRICS_PER_REPO=true`** on the app container. Values are gauges refreshed on sync/scrape (not continuous traffic).",
        "mode": "markdown"
      },
      "title": "Note",
      "type": "text"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 12,
      "options": {
        "displayMode": "gradient",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sortBy": "value",
        "sortOrder": "desc"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sort_desc(topk(10, gghstats_repo_clones_7d))",
          "instant": true,
          "legendFormat": "{{owner}}/{{repo}}",
          "refId": "A"
        }
      ],
      "title": "Top repos by clones (7d)",
      "type": "bargauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 13,
      "options": {
        "displayMode": "gradient",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "sortBy": "value",
        "sortOrder": "desc"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sort_desc(topk(10, gghstats_repo_clones_30d))",
          "instant": true,
          "legendFormat": "{{owner}}/{{repo}}",
          "refId": "A"
        }
      ],
      "title": "Top repos by clones (30d)",
      "type": "bargauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["gghstats", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "gghstats — Domain metrics",
  "uid": "gghstats-domain",
  "version": 4
}
