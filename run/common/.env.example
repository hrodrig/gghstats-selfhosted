# gghstats-selfhosted — template for Docker Compose variable substitution. Do not commit real secrets.
#
# This repository’s own semver is in VERSION at the repository root — bump for infra/doc/layout releases, not for app code.
#
# Typical locations (pick one):
#   • Repository root:  ./.env  (quick start; pair with default GGHSTATS_HOST_DATA or repo data/)
#   • Persistent dir:   /home/gghstats/gghstats-data/.env  (recommended on servers — same folder as SQLite)
#
# When secrets live outside the clone (e.g. /home/gghstats/gghstats-data/.env), run Compose from the repo root with:
#   docker compose --env-file /home/gghstats/gghstats-data/.env -f run/docker-compose/traefik/docker-compose.yml up -d
# Set GGHSTATS_HOST_DATA to that same directory so the DB sits next to the env files.
#
# Observability (optional): copy run/docker-compose/observability/observability.env.example to
#   ${GGHSTATS_HOST_DATA}/.env.observability  (outside this repo — same directory as SQLite / main .env)
# and pass the path in every observability compose command (--env-file …).

# --- gghstats (required) ---
GGHSTATS_GITHUB_TOKEN=

# Container image tag — must match a published ghcr.io/hrodrig/gghstats release (see gghstats VERSION / tags).
# Unrelated to the gghstats-selfhosted VERSION file (manifests repo).
GGHSTATS_VERSION=v0.1.2

# Host directory bind-mounted to /data in the container (SQLite). Prefer an absolute path on servers, e.g.:
#   /home/gghstats/gghstats-data
#   /var/lib/gghstats
# If unset, Compose uses the repository data/ directory (see run/docker-compose/*/docker-compose.yml).
# GGHSTATS_HOST_DATA=

# --- run/docker-compose/minimal/docker-compose.yml (optional overrides) ---
GGHSTATS_PORT=8080
GGHSTATS_FILTER=*
GGHSTATS_SYNC_INTERVAL=1h

# --- run/docker-compose/traefik/docker-compose.yml (Traefik + TLS) ---
GGHSTATS_HOSTNAME=stats.example.com
ACME_EMAIL=you@example.com
# Numeric UID/GID for the gghstats container user; must own GGHSTATS_HOST_DATA (or repo data/ if unset)
GGS_UID=1000
GGS_GID=1000

# --- Observability — see run/docker-compose/observability/observability.env.example → ${GGHSTATS_HOST_DATA}/.env.observability ---
