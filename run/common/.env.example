# gghstats-selfhosted — template for Docker Compose variable substitution. Do not commit real secrets.
#
# This repository’s own semver is in VERSION at the repository root — bump for infra/doc/layout releases, not for app code.
#
# Recommended: keep SQLite and this file under one host directory (outside the git clone).
#   1. export GGHSTATS_HOST_DATA=/home/gghstats/gghstats-data   # example
#   2. mkdir -p "$GGHSTATS_HOST_DATA"
#   3. Copy this file to "${GGHSTATS_HOST_DATA}/.env" and edit secrets.
#   4. Set GGHSTATS_HOST_DATA in that .env to the same absolute path (required for volume mounts).
#   5. From the clone root:
#        docker compose --env-file "${GGHSTATS_HOST_DATA}/.env" -f run/docker-compose/minimal/docker-compose.yml up -d
#
# Optional (local dev only): copy to ./.env at the repository root and leave GGHSTATS_HOST_DATA unset — Compose
# falls back to the repo’s data/ directory (see run/docker-compose/*/docker-compose.yml).
#
# Observability (optional): same GGHSTATS_HOST_DATA as above — copy
#   run/docker-compose/observability/observability.env.example → ${GGHSTATS_HOST_DATA}/.env.observability
# and use --env-file "${GGHSTATS_HOST_DATA}/.env.observability" on every observability compose command (-p gghstats-obs).

# --- gghstats (required) ---
GGHSTATS_GITHUB_TOKEN=

# Container image tag — must match a published ghcr.io/hrodrig/gghstats release (see gghstats VERSION / tags).
# Unrelated to the gghstats-selfhosted VERSION file (manifests repo).
GGHSTATS_VERSION=v0.1.4

# Host directory bind-mounted to /data in the container (SQLite). Prefer an absolute path on servers, e.g.:
#   /home/gghstats/gghstats-data
#   /var/lib/gghstats
# If unset, Compose uses the repository data/ directory (see run/docker-compose/*/docker-compose.yml).
# Uncomment and set when using "${GGHSTATS_HOST_DATA}/.env" (recommended on servers):
# GGHSTATS_HOST_DATA=/home/gghstats/gghstats-data

# --- run/docker-compose/minimal/docker-compose.yml (optional overrides) ---
GGHSTATS_PORT=8080
GGHSTATS_FILTER=*
GGHSTATS_SYNC_INTERVAL=1h
# Include private repos in sync (requires GitHub PAT with repo scope — see gghstats README).
GGHSTATS_INCLUDE_PRIVATE=false
# Optional: require header x-api-token on /api/* (see gghstats README).
GGHSTATS_API_TOKEN=

# --- run/docker-compose/traefik/docker-compose.yml (Traefik + TLS) ---
GGHSTATS_HOSTNAME=stats.example.com
ACME_EMAIL=you@example.com
# Numeric UID/GID for the gghstats container user; must own GGHSTATS_HOST_DATA (or repo data/ if unset)
GGS_UID=1000
GGS_GID=1000

# --- Observability — template: run/docker-compose/observability/observability.env.example → ${GGHSTATS_HOST_DATA}/.env.observability ---
